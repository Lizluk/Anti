local BtnSavePose = Instance.new("TextButton", MF); BtnSavePose.Size = UDim2.new(0.5,-15,0,35); BtnSavePose.Position = UDim2.new(0,10,0,450); BtnSavePose.Text = "SAVE POSE"; BtnSavePose.BackgroundColor3 = Color3.fromRGB(50,150,50); BtnSavePose.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", BtnSavePose)
local BtnSavePoint = Instance.new("TextButton", MF); BtnSavePoint.Size = UDim2.new(0.5,-15,0,35); BtnSavePoint.Position = UDim2.new(0.5,5,0,450); BtnSavePoint.Text = "SAVE POINT"; BtnSavePoint.BackgroundColor3 = Color3.fromRGB(150,100,50); BtnSavePoint.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", BtnSavePoint)

