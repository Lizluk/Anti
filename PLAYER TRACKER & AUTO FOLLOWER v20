-- HÀM CẬP NHẬT DANH SÁCH VÀ NÚT XÓA
local function updateUI()
    for _, v in pairs(TabPose:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for _, v in pairs(TabPos:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    
    -- Danh sách Poses
    for i, fav in ipairs(favorites) do
        local f = Instance.new("Frame", TabPose); f.Size = UDim2.new(1, -5, 0, 28); f.BackgroundColor3 = Color3.fromRGB(45, 45, 60); Instance.new("UICorner", f)
        local b = Instance.new("TextButton", f); b.Size = UDim2.new(0.75, 0, 1, 0); b.Text = fav.name; b.TextColor3 = Color3.new(1,1,1); b.BackgroundTransparency = 1; b.TextSize = 10
        local d = Instance.new("TextButton", f); d.Size = UDim2.new(0.25, 0, 1, 0); d.Position = UDim2.new(0.75, 0, 0, 0); d.Text = "X"; d.TextColor3 = Color3.new(1, 0.2, 0.2); d.Font = "GothamBold"; d.BackgroundTransparency = 1
        
        b.MouseButton1Click:Connect(function() followSettings.distance, followSettings.height, followSettings.side, followSettings.tilt, followSettings.angle = fav.distance, fav.height, fav.side, fav.tilt, fav.angle end)
        d.MouseButton1Click:Connect(function() table.remove(favorites, i); saveData(); updateUI() end)
    end
    
    -- Danh sách Points
    for i, p in ipairs(savedPositions) do
        local f = Instance.new("Frame", TabPos); f.Size = UDim2.new(1, -5, 0, 28); f.BackgroundColor3 = Color3.fromRGB(60, 45, 45); Instance.new("UICorner", f)
        local b = Instance.new("TextButton", f); b.Size = UDim2.new(0.75, 0, 1, 0); b.Text = p.name; b.TextColor3 = Color3.new(1,1,1); b.BackgroundTransparency = 1; b.TextSize = 10
        local d = Instance.new("TextButton", f); d.Size = UDim2.new(0.25, 0, 1, 0); d.Position = UDim2.new(0.75, 0, 0, 0); d.Text = "X"; d.TextColor3 = Color3.new(1, 0.2, 0.2); d.Font = "GothamBold"; d.BackgroundTransparency = 1
        
        b.MouseButton1Click:Connect(function() followSettings.mode = "Static"; followSettings.staticPos = Vector3.new(p.x, p.y, p.z); followSettings.enabled = true end)
        d.MouseButton1Click:Connect(function() table.remove(savedPositions, i); saveData(); updateUI() end)
    end
end

