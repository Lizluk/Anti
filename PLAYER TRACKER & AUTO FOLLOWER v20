local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")

local LP = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local fileName = "FollowerFull_V23.json"

local followSettings = {
    enabled = false,
    target = nil,
    mode = "Follow",
    staticPos = Vector3.new(0,0,0),
    distance = 1.5,
    height = 0,
    side = 0,
    tilt = 0,
    angle = 180
}

local favorites = {}
local savedPositions = {}

-- =============================================
-- DATA SYSTEM[cite: 1, 2]
-- =============================================
local function saveData()
    local success, err = pcall(function()
        writefile(fileName, HttpService:JSONEncode({favorites = favorites, savedPositions = savedPositions}))
    end)
    if not success then warn("Lỗi lưu file: " .. err) end
end

local function loadData()
    if isfile(fileName) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(fileName)) end)
        if success then
            favorites = data.favorites or {}
            savedPositions = data.savedPositions or {}
        end
    end
end
loadData()

-- =============================================
-- CORE LOGIC (V23 - ANTI-TILT UP)
-- =============================================
RunService.Heartbeat:Connect(function()
    if not followSettings.enabled then return end
    local myChar = LP.Character 
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myHRP = myChar.HumanoidRootPart
    
    local targetPos, targetHRP
    if followSettings.mode == "Follow" and followSettings.target then
        local tChar = followSettings.target.Character
        if tChar and tChar:FindFirstChild("HumanoidRootPart") then
            targetHRP = tChar.HumanoidRootPart
            targetPos = targetHRP.Position
        else return end
    elseif followSettings.mode == "Static" then
        targetPos = followSettings.staticPos
    else return end
    
    local rotation = CFrame.Angles(0, math.rad(followSettings.angle), 0)
    local baseCF = (targetHRP and targetHRP.CFrame or CFrame.new(targetPos)) * rotation
    
    local horizontalOffset = (baseCF.LookVector * followSettings.distance) + (baseCF.RightVector * followSettings.side)
    local goalPos = targetPos + horizontalOffset + Vector3.new(0, followSettings.height, 0)
    
    -- Khóa người đứng thẳng (chỉ xoay trục Y)
    local lookDirection = (targetPos - goalPos).Unit
    local targetRotationY = math.atan2(lookDirection.X, lookDirection.Z)
    
    myHRP.CFrame = CFrame.new(goalPos) * CFrame.Angles(0, targetRotationY + math.pi, 0) * CFrame.Angles(math.rad(followSettings.tilt), 0, 0)
    myHRP.Velocity = Vector3.zero
end)

