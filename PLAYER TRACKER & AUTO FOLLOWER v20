local MF = Instance.new("Frame", SG); MF.Size = UDim2.new(0, 340, 0, 700); MF.Position = UDim2.new(1, -350, 0.5, -350); MF.BackgroundColor3 = Color3.fromRGB(25, 25, 35); Instance.new("UICorner", MF)
local TB = Instance.new("Frame", MF); TB.Size = UDim2.new(1, 0, 0, 35); TB.BackgroundColor3 = Color3.fromRGB(80, 50, 200); Instance.new("UICorner", TB)
local TL = Instance.new("TextLabel", TB); TL.Size = UDim2.new(1, 0, 1, 0); TL.Text = "FOLLOW V22 - UPRIGHT LOCK"; TL.TextColor3 = Color3.new(1, 1, 1); TL.Font = "GothamBold"; TL.BackgroundTransparency = 1

local function createSlider(text, min, max, key, pos)
    local label = Instance.new("TextLabel", MF); label.Size = UDim2.new(1,-20,0,15); label.Position = UDim2.new(0,10,0,pos+45); label.TextColor3 = Color3.new(1,1,1); label.Font = "GothamBold"; label.TextSize = 10; label.BackgroundTransparency = 1
    local bg = Instance.new("Frame", MF); bg.Size = UDim2.new(1,-20,0,6); bg.Position = UDim2.new(0,10,0,pos+63); bg.BackgroundColor3 = Color3.fromRGB(45,45,60); Instance.new("UICorner", bg)
    local fill = Instance.new("Frame", bg); fill.BackgroundColor3 = Color3.fromRGB(120, 200, 255); Instance.new("UICorner", fill)
    RunService.RenderStepped:Connect(function()
        fill.Size = UDim2.new(math.clamp((followSettings[key] - min)/(max - min), 0, 1), 0, 1, 0)
        label.Text = text .. ": " .. string.format("%.1f", followSettings[key])
    end)
    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local conn; conn = RunService.RenderStepped:Connect(function()
                if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then conn:Disconnect() return end
                followSettings[key] = min + (math.clamp((UserInputService:GetMouseLocation().X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1) * (max - min))
            end)
        end
    end)
end

createSlider("↔️ Distance", -100, 100, "distance", 0)
createSlider("↕️ Height (Fixed Upright)", -100, 100, "height", 40)
createSlider("⬅️➡️ Side", -100, 100, "side", 80)
createSlider("📐 Tilt (Nghiêng người)", -180, 180, "tilt", 120)
createSlider("🔄 Angle", -360, 360, "angle", 160)

local TabPose = Instance.new("ScrollingFrame", MF); TabPose.Size = UDim2.new(0.5,-15,0,150); TabPose.Position = UDim2.new(0,10,0,245); TabPose.BackgroundColor3 = Color3.fromRGB(15,15,25); Instance.new("UIListLayout", TabPose).Padding = UDim.new(0,2)
local TabPos = Instance.new("ScrollingFrame", MF); TabPos.Size = UDim2.new(0.5,-15,0,150); TabPos.Position = UDim2.new(0.5,5,0,245); TabPos.BackgroundColor3 = Color3.fromRGB(15,15,25); Instance.new("UIListLayout", TabPos).Padding = UDim.new(0,2)

local function updateUI()
    for _, v in pairs(TabPose:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for _, v in pairs(TabPos:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for i, f in ipairs(favorites) do
        local fr = Instance.new("Frame", TabPose); fr.Size = UDim2.new(1,-5,0,28); fr.BackgroundColor3 = Color3.fromRGB(40,40,60); Instance.new("UICorner", fr)
        local b = Instance.new("TextButton", fr); b.Size = UDim2.new(0.7,0,1,0); b.Text = f.name; b.TextColor3 = Color3.new(1,1,1); b.BackgroundTransparency = 1; b.TextSize = 10
        b.MouseButton1Click:Connect(function() followSettings.distance, followSettings.height, followSettings.side, followSettings.tilt, followSettings.angle = f.distance, f.height, f.side, f.tilt, f.angle end)
    end
    for i, p in ipairs(savedPositions) do
        local fr = Instance.new("Frame", TabPos); fr.Size = UDim2.new(1,-5,0,28); fr.BackgroundColor3 = Color3.fromRGB(60,40,40); Instance.new("UICorner", fr)
        local b = Instance.new("TextButton", fr); b.Size = UDim2.new(1,0,1,0); b.Text = p.name; b.TextColor3 = Color3.new(1,1,1); b.BackgroundTransparency = 1; b.TextSize = 10
        b.MouseButton1Click:Connect(function() followSettings.mode = "Static"; followSettings.staticPos = Vector3.new(p.x, p.y, p.z); followSettings.enabled = true end)
    end
end

